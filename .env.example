# KnowledgeForge — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env && nano .env

# ── Telegram Digest Delivery ──
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_group_chat_id
# JSON map of category → topic thread ID
TELEGRAM_TOPIC_IDS={"bugbounty":2,"ai-money":3,"saas-niches":4,"crypto-defi":5,"attacking-ai":6,"tools-drops":7,"general":8,"status":9}

# ── Telegram Channel Ingestion (optional) ──
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ── Internal (set by docker-compose, rarely changed) ──
# KF_DB_PATH=/app/data/kf.db
# RSSHUB_URL=http://rsshub:1200
# KB_API_BASE=http://api:8000
# KF_COOKIES=/app/cookies/cookies.txt
